# moneycollector — .env (copy to `.env` and edit)
#
# 99% of users don't need to touch this file. All wallets, recipients, and
# funder keys are managed by the interactive wizard (`npm start` or the
# .exe). This file holds advanced knobs: RPC overrides, slippage, pacing.

# ===== Destination chain randomization =====
# Comma-separated list of EVM destination chains. One is picked at random per
# source wallet during EVM real mode. Both are well-supported by Relay.link.
DEST_CHAINS=arbitrum,base

# ===== Sweep behaviour =====
# 0 = let the script decide per token using the Relay/LI.FI net-profit check
# (output_usd > origin_gas_usd). Set a positive number to add a hard floor.
MIN_TOKEN_USD=0

# Parallel wallets in real mode. Keep low on public RPCs (2-3); raise on paid.
CONCURRENCY=2

# Slippage in basis points (100 = 1%).
SLIPPAGE_BPS=100

# ===== Squid Router (Fantom bridge) =====
# Fantom Opera (chainId 250) is bridged via Squid (powered by Axelar) because
# Relay never supported it and LI.FI dropped it in 2026 after liquidity moved
# to Sonic. Squid requires a REGISTERED integrator id — there is no public
# anonymous key. To enable Fantom dust bridging:
#   1. Apply at https://squidrouter.typeform.com/integrator-id  (~24h approval)
#   2. Paste the returned ID below
# Until set, Fantom dust gets swept onto your hub (ULTRA mode) but is not
# bridged onward — it sits as FTM on the hub for manual recovery.
SQUID_INTEGRATOR_ID=

# ===== EVM gas funder (optional) =====
# The wizard collects funder private keys interactively and writes them to
# data/funders-evm.txt. For power-users / scripted runs, a SINGLE key here
# is used as a fallback if the file is empty. Multiple keys are NOT
# supported via env — use the wizard for that.
GAS_FUNDER_PRIVATE_KEY=
# Max USD value the funder will send per top-up. Bump to $1-2 if zkSync
# sweeps fail with INSUFFICIENT_FUNDS (zkSync upfront-fee gap).
GAS_FUNDER_MAX_USD_PER_TOPUP=0.50

# ===== EVM RPC overrides (optional) =====
# Each of the 17 EVM chains ships with 3 public RPC defaults baked into
# src/config/chains.ts (verified live). The discovery layer rotates to the
# next on consecutive failures.
#
# To override: set RPC_<CHAIN> to make YOUR endpoint the PRIMARY. Bundled
# defaults are appended as backups, so failover still works. Pin up to 2
# additional backups via RPC_<CHAIN>_2 / _3 if you want full rotation
# control (e.g., paid endpoints first).
RPC_ETHEREUM=
RPC_ETHEREUM_2=
RPC_ETHEREUM_3=
RPC_ARBITRUM=
RPC_ARBITRUM_2=
RPC_ARBITRUM_3=
RPC_OPTIMISM=
RPC_OPTIMISM_2=
RPC_OPTIMISM_3=
RPC_BASE=
RPC_BASE_2=
RPC_BASE_3=
RPC_POLYGON=
RPC_POLYGON_2=
RPC_POLYGON_3=
RPC_BSC=
RPC_BSC_2=
RPC_BSC_3=
RPC_OPBNB=
RPC_OPBNB_2=
RPC_OPBNB_3=
RPC_AVALANCHE=
RPC_AVALANCHE_2=
RPC_AVALANCHE_3=
RPC_FANTOM=
RPC_FANTOM_2=
RPC_FANTOM_3=
RPC_CELO=
RPC_CELO_2=
RPC_CELO_3=
RPC_LINEA=
RPC_LINEA_2=
RPC_LINEA_3=
RPC_SCROLL=
RPC_SCROLL_2=
RPC_SCROLL_3=
RPC_ZKSYNC=
RPC_ZKSYNC_2=
RPC_ZKSYNC_3=
RPC_ZORA=
RPC_ZORA_2=
RPC_ZORA_3=
RPC_MODE=
RPC_MODE_2=
RPC_MODE_3=
RPC_BLAST=
RPC_BLAST_2=
RPC_BLAST_3=
RPC_ABSTRACT=
RPC_ABSTRACT_2=
RPC_ABSTRACT_3=

# ===== Solana RPC =====
# Public api.mainnet-beta.solana.com is heavily rate-limited (~2 heavy calls
# → 5s of 429s). For ≥10 wallets you NEED a paid endpoint. Recommended:
# free Helius API key from https://www.helius.dev — ~100 RPC/s, enough for
# hundreds of dust wallets.
# Format:  RPC_SOLANA=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
RPC_SOLANA=
RPC_SOLANA_2=
RPC_SOLANA_3=
# Inter-wallet delay during Solana scan/collect. Default 1500ms is tuned for
# public mainnet-beta. With Helius/Alchemy paid, drop to 100-200ms for a
# 10-15× speedup.
SOLANA_PACE_MS=
# Backoff after 429 before retrying / rotating. Default 5000ms.
SOLANA_429_BACKOFF_MS=

# ===== Jupiter (Solana swap aggregator) =====
# Free `lite-api.jup.ag/swap/v1` is throttled to ~60 req/min; script paces
# to 1.1s and caches TOKEN_NOT_TRADABLE mints across wallets.
# Paid key (https://portal.jup.ag/) switches to `api.jup.ag/swap/v1` and
# drops throttle to 200ms.
JUP_API_KEY=
JUP_BASE=
JUP_MIN_INTERVAL_MS=
JUP_429_BACKOFF_MS=
# Solana scan: quote each SPL token to show USD + "tradable / spam". =0
# skips Jupiter during scan (much faster, no USD). Default 1.
SOLANA_SCAN_QUOTES=

# ===== Solana gas funder (optional, single-key fallback) =====
# Wizard manages multi-key funder in data/funders-sol.txt. This is the
# fallback when the file is absent. Accepts base58 (Phantom) or JSON-array
# (Solana CLI). Pre-fund ~0.05 SOL — covers ~100 dust wallets.
SOL_GAS_FUNDER_PRIVATE_KEY=
# Dust wallet minimum SOL balance before swap (lamports). Default 2_240_000
# = ATA rent (2_039_280) + 200k slack for Jupiter priority fees.
SOL_MIN_FOR_SWAP_LAMPORTS=
# Max lamports per upfront top-up. Default 2_300_000.
SOL_FUNDER_TOPUP_LAMPORTS=
# Cap on the retry-top-up triggered when a swap simulation runs out of gas.
# Default 1_000_000 (~$0.09). Anti-runaway guard if the deficit parser slips.
SOL_FUNDER_RETRY_CAP_LAMPORTS=
