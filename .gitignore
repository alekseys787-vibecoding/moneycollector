data/seeds-sol-active.txt

# Wallets (raw private keys)
data/privkeys-evm.txt
data/privkeys-sol.txt

# Recipients (user-provided lists + wizard-generated wallets with mnemonics)
data/recipients-evm.txt
data/recipients-sol.txt
data/generated-recipients-*.txt

# Funder private keys (rotation lists)
data/funders-evm.txt
data/funders-sol.txt

# Per-user custom-token additions (the .example stays in repo)
data/custom-tokens.json

