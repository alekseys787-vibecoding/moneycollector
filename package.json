{
  "name": "moneycollector",
  "version": "0.1.0",
  "private": true,
  "description": "Dust collector across EVM L1/L2s and Solana. Interactive wizard sweeps small balances, swaps to native via Relay.link / LI.FI / Jupiter, splits 90% to user recipients / 10% to dev fee.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "start:built": "node dist/index.js",
    "build:exe": "node scripts/build-exe.mjs"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "bip39": "^3.1.0",
    "chalk": "^4.1.2",
    "dotenv": "^16.4.5",
    "ed25519-hd-key": "^1.3.0",
    "ethers": "^6.13.4",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/prompts": "^2.4.9",
    "@yao-pkg/pkg": "^6.6.0",
    "javascript-obfuscator": "^4.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  },
  "overrides": {
    "ws": "^8.20.1",
    "uuid": "^11.1.1"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "node_modules/bip39/src/wordlists/*.json"
    ],
    "targets": [
      "node20-win-x64"
    ]
  },
  "engines": {
    "node": ">=18.18"
  }
}
